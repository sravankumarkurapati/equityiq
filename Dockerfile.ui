# Dockerfile.ui
#
# Single-stage build for the Streamlit frontend.
# Simpler than the API Dockerfile because Streamlit
# has fewer heavy dependencies.
#
# Build with:
#   docker build -f Dockerfile.ui -t equityiq-ui .

FROM python:3.11-slim

WORKDIR /app

RUN apt-get update && apt-get install -y curl \
    && rm -rf /var/lib/apt/lists/*

# Copy and install frontend requirements
COPY frontend/requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# Copy frontend source
COPY frontend/ ./frontend/

# Add project root to Python path
# Needed so frontend can import from backend (config etc.)
ENV PYTHONPATH=/app
ENV PYTHONUNBUFFERED=1

EXPOSE 8501

HEALTHCHECK --interval=30s --timeout=10s --retries=3 \
    CMD curl -f http://localhost:8501/_stcore/health || exit 1

# Streamlit flags:
# --server.headless=true    dont try to open browser
# --server.enableCORS=false nginx handles CORS
# --server.address=0.0.0.0  accept external connections
CMD ["streamlit", "run", "frontend/app.py", \
     "--server.port=8501", \
     "--server.address=0.0.0.0", \
     "--server.headless=true", \
     "--server.enableCORS=false"]